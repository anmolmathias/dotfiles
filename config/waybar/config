        "artist-len": 25,
        "title-len": 30,
	"ignored-players":["kdeconnect"]
    },

    "sway/mode": {
        "format": " ’üź "
    },
    "custom/clock": {
        "format": "{}",
        "exec": "date +'%H:%M'",
        "interval": 3
    },

    "sway/window": {
	"format": "            {}",
	"all-outputs": true,
	"offscreen-css": false,
	"max-length": 70
},

 "network": {
        "format": "",
