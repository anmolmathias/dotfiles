{
    "layer": "bottom",
    "position": "bottom",
    "height": 30,
    "spacing": 0,
    "modules-left": ["sway/workspaces","wlr/taskbar"],
    "modules-center": [],
    "modules-right": ["mpris", "sway/mode", "network", "bluetooth", "pulseaudio", "idle_inhibitor", "custom/theme-mode", "battery", "custom/clock"],

    "sway/workspaces": {
        "disable-scroll": false,
        "format": "{name}"
    },

"wlr/taskbar": {
	"format": "{icon}  {title:.30}",
	"icon-size": 14,
	"icon-theme": "Yaru-yellow",
	"tooltip-format": "{title}",
	"on-click": "activate",
	"on-click-middle": "close"
},



"mpris": {
        "format": "{player_icon}  {artist} - {title}",
        "format-paused": "{status_icon} {artist} - {title}",
        "max-length": 80,
        "player-icons": {
            "default": "’üŗ ",
