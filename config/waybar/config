{
    "layer": "bottom",
    "position": "bottom",
    "height": 30,
    "spacing": 0,
    "modules-left": ["sway/workspaces","wlr/taskbar"],
    "modules-center": [],
    "modules-right": ["mpris", "sway/mode", "network", "bluetooth", "pulseaudio", "idle_inhibitor", "custom/theme-mode", "battery", "clock"],

    "sway/workspaces": {
        "disable-scroll": false,
        "format": "{name}"
    },

"wlr/taskbar": {
	"format": "{icon}  {title:.30}",
	"icon-size": 14,
	"icon-theme": "Yaru-blue",
	"tooltip-format": "{title}",
	"on-click": "minimize-raise",
	"on-click-middle": "close"
},



"mpris": {
        "format": "<span size='x-large' rise='-1200' color='#a56de2'>{player_icon}</span> {artist} - {title}",
        "format-paused": "{status_icon} {artist} - {title}",
        "max-length": 80,
        "player-icons": {
            "default": "пЃ‹ ",
	    "Feishin": "у°Ћ† ",
            "spotify": "п†ј ",
	    "mpv": "пЌ® "
        },
        "status-icons": {
            "paused": "пЉ‹  "
        },
        "artist-len": 25,
        "title-len": 30,
	"ignored-players":["kdeconnect"]
    },

    "sway/mode": {
        "format": " пЃҐ "
    },
    "clock": {
        "format": "{:%a %b %d  %H:%M}",
	"tooltip": true,
	"tooltip-format": "<tt><small><span size='10pt' font='PragmataPro'>{calendar}</span></small></tt>",
	"calendar": {
		"mode": "month",
		"format": {
                	"months": "<span color='#f4679d'><b>{}</b></span>",
                        "days": "<span color='#fafafa'><b>{}</b></span>",
                	"weekdays": "<span color='#9bdb4d'><b>{}</b></span>",
                	"today": "<span color='#f9c440'><b>{}</b></span>"
            	}
	},
	"actions": {
		"on-scroll-up": "shift_up",
		"on-scroll-down": "shift_down"
	}
    },

    "sway/window": {
	"format": "            {}",
	"all-outputs": true,
	"offscreen-css": false,
	"max-length": 70
},

 "network": {
        "format": "",
        "format-ethernet": "у°€Ђ",
        "format-wifi": "у°–©",
        "format-disconnected": "у±љј",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname}",
        "tooltip-format-disconnected": "Disconnected",
	"on-click": "foot nmtui"
    },

    "pulseaudio": {
        "format": "{icon}",
	"format-muted": "п‘¦",
	"format-icons": {
		"headphone": "пЂҐ",
		"headset": "пЂҐ",
		"hifi": "у°“ѓ",
		"default": ["пЂ¦", "пЂ§", "пЂЁ"]
	},
	"on-click": "foot pulsemixer",
	"on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
	"on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ && paplay ~/.local/share/sounds/elementary/stereo/audio-volume-change.wav",
	"on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && paplay ~/.local/share/sounds/elementary/stereo/audio-volume-change.wav",
	"tooltip-format": "Vol: {volume}",
	"max-volume": "100"
    },


"bluetooth": {
	"format": "у°‚Ї",
	"format-disabled": "у°‚І",
	"format-connected": "пЉ“",
	"on-click": "blueman-manager"
},

"idle_inhibitor": {
	"format": "{icon}",
	"format-icons": {
		"activated": "пЃ®",
		"deactivated": "пЃ°"
	},
	"timeout": 180
},

"custom/theme-mode": {
	"format": "пЃ‚",
	"tooltip": false,
	"on-click": "bash /home/nml/.local/bin/switch-theme-mode"
},
    
    "battery": {
        "interval": 60,
	"states": {
		"warning": 30,
		"critical": 15,
		"default": 100
	},
        "format": "{icon}",
        "format-icons": {
		"default": ["у°‚ѓ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
		"charging": ["у°ўџ ", "у°ўњ ", "у°‚† ", "у°‚‡ ", "у°‚€ ", "у°ўќ ", "у°‚‰ ", "у°ўћ ", "у°‚Љ ", "у°‚‹ ", "у°‚„ "]
    },
        "tooltip-format": "{capacity}%"
    },

    "backlight": {
        "format": "<b>mon:</b> {percent}%",
        "tooltip": false
    },
    
    "tray": {
        "icon-size": 20,
        "spacing": 7,
        "tooltip": false
    }
}
