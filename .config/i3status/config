# i3status configuration file.
#
# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
	color_good = "#6CFBB8"
	color_degraded = "#F7FB6C"
	color_bad = "#FB716C"
        interval = 1
}

#order += "ipv6"
order += "wireless _first_"
order += "ethernet _first_"
order += "battery all"
#order += "disk /"
#order += "load"
order += "memory"
order += "volume master"
order += "tztime local"

wireless _first_ {
        format_up = " %essid "
        format_down = " --- "
}

ethernet _first_ {
        format_up = " %ip: %speed "
        format_down = ""
}

battery all {
        format = " %status %percentage "
	status_chr = "CHR"
	status_bat = "BAT"
        status_unk = "UNK"
        status_full = "FULL"
	low_threshold= 30
	threshold_type= time
}

disk "/" {
        format = "%avail"
}

load {
        format = "%1min"
}

memory {
        format = " RAM %used "
        threshold_degraded = "1G"
        format_degraded = "MEMORY < %available"
}

tztime local {
        format = " %d/%m %H:%M:%S "
}

volume master {
        format = " VOL %volume "
        format_muted = " MUTE (%volume)"
        device = "default"
        mixer = "Master"
        mixer_idx = 0
}
